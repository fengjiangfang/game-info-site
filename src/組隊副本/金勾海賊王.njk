---
layout: layout.njk
title: 金勾海賊王
---
{% from "dungeon-macros.njk" import dungeonHeader, stageRow, npc, mob, item, itemBold, dungeonNav %}

<div class="forum-banner">
    <div class="forum-banner-content">
        <h1>金勾海賊王</h1>
    </div>
</div>

<div class="forum-main-card forum-main-card-warm">
    
    {{ dungeonHeader('５５等 ↑', '３～６人', '３５０００', {
        clear: [
            { name: '金勾組隊硬幣', value: '1 個' },
            { name: '洗血精華秘藥罐', value: '10 個' }
        ],
        chance: [
            { name: '轉蛋券', value: '1 個' }
        ],
        exchange: [
            { name: '經驗加倍券', cost: '5 硬幣', value: '四屬+1' },
            { name: '金勾組隊騎寵', cost: '20 硬幣', value: '四屬+1' }
        ],
        run: [
            { name: '金勾組隊稱號', value: '四屬+1' }
        ],
        requirement: [
            { name: '金勾組隊硬幣', value: '1 個' },
            { name: '一百萬楓幣袋', value: '10 個' }
        ]
    }, '金勾海賊王', '靈藥幻境:海盜船境地') }}

    <ul class="dungeon-timeline-full">
        {% call() stageRow(1, '前往海盜船之路', '金勾海賊王') %}
        <ul class="rule-list">
            <li>清除地圖上所有怪物，即可通過傳點進入下一階段。</li>
        </ul>
        {% endcall %}

        {% call() stageRow(2, '突破船首!', '金勾海賊王') %}
        <ul class="rule-list">
            <li>地圖上所有怪物擊殺後皆會掉落海賊的象徵。</li>
            <li>由隊長與 {{ npc('邱翁NPC', '金勾海賊王/邱翁NPC.png', 2) }} 對話，提交三次指定的任務道具：</li>
            <li>第一次 → {{ item('新手海賊的象徵') }} 20 個</li>
            <li>第二次 → {{ item('中級海賊的象徵') }} 20 個</li>
            <li>第三次 → {{ item('老手海賊的象徵') }} 20 個</li>
            <li>全部完成後即可通過傳點進入下一階段。</li>
        </ul>
        {% endcall %}

        {% call() stageRow(3, '突破甲板 I', '金勾海賊王') %}
        <ul class="rule-list">
            <li>清除地圖上所有怪物，即可通過傳點進入下一階段。</li>
        </ul>
        {% endcall %}

        {% call() stageRow(4, '突破甲板 II', '金勾海賊王') %}
        <ul class="rule-list">
            <li>清除地圖上所有怪物，即可通過傳點進入下一階段。</li>
        </ul>
        {% endcall %}

        {% call() stageRow(5, '打倒海賊!', '金勾海賊王') %}
        <ul class="rule-list">
            <li>地圖上所有怪物擊殺後皆會掉落 {{ item('老舊的鐵鑰匙') }}</li>
            <li>將 {{ item('老舊的鐵鑰匙') }} 放置在中間的四扇門前，等待數秒後即可讓門關上。</li>
            <li>四扇門全部關閉後，<strong>且所有隊員皆來到此地圖</strong>，即可通過傳點進入下一階段。</li>
        </ul>
        {% endcall %}

        {% call() stageRow(6, '海賊王的最後', '金勾海賊王') %}
        <ul class="rule-list">
            <li>擊敗最終 BOSS 後，與 {{ npc('邱翁NPC', '金勾海賊王/邱翁NPC.png', 6) }} 對話即可通關。</li>
        </ul>
        {% endcall %}
    </ul>
    
    {{ dungeonNav('組隊', '女神的痕跡', '羅密歐與茱麗葉') }}

</div>