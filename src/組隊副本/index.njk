---
layout: layout.njk
title: 組隊副本
---

<div class="dungeon-index-header">
    <h1 class="dungeon-index-title">組隊副本 (Party Quest)</h1>
    <p class="dungeon-index-subtitle">集結夥伴的力量，獲取傳說中的戰利品！</p>
</div>

<div class="dungeon-grid">
    {% set quests = [
        { name: '第一次同行', level: '21 ~ 30等', npc: '拉克拉蘭', img: '第一次同行/1.gif', url: '/組隊副本/第一次同行/' },
        { name: '時空的裂縫', level: '35 ~ 200等', npc: '補確', img: '時空的裂縫/1.gif', url: '/組隊副本/時空的裂縫/' },
        { name: '毒霧森林', level: '45 ~ 200等', npc: '艾利遜', img: '毒霧森林/1.gif', url: '/組隊副本/毒霧森林/' },
        { name: '女神的痕跡', level: '51 ~ 200等', npc: '元氣', img: '女神的痕跡/npc.png', url: '/組隊副本/女神的痕跡/' },
        { name: '金勾海賊王', level: '55 ~ 200等', npc: '巫師', img: '金勾海賊王/npc.png', url: '/組隊副本/金勾海賊王/' },
        { name: '羅密歐與茱麗葉', level: '70 ~ 200等', npc: '朱律安', img: '羅密歐與茱麗葉/npc.png', url: '/組隊副本/羅密歐與茱麗葉/' }
    ] %}

    {% for quest in quests %}
    <a href="{{ quest.url | url }}" class="dungeon-card">
        <div class="dungeon-card-img-wrapper">
            <img src="{{ ('/images/' + quest.img) | url }}" alt="{{ quest.name }}">
        </div>
        <div class="dungeon-card-content">
            <h3 class="dungeon-card-name">{{ quest.name }}</h3>
            <div class="dungeon-card-meta">
                <span class="dungeon-meta-label">等級：</span>
                <span class="dungeon-meta-value">{{ quest.level }}</span>
            </div>
            <div class="dungeon-card-meta">
                <span class="dungeon-meta-label">NPC：</span>
                <span class="dungeon-meta-value">{{ quest.npc }}</span>
            </div>
            <span class="dungeon-card-btn">查看攻略</span>
        </div>
    </a>
    {% endfor %}
</div>

<style>
.dungeon-index-header { text-align: center; margin-bottom: 40px; padding: 40px 20px; background: rgba(0,0,0,0.2); border-radius: 15px; border: 1px solid rgba(255,255,255,0.05); }
.dungeon-index-title { font-size: 28px; color: #ffeb3b; margin-bottom: 10px; font-weight: bold; text-shadow: 2px 2px 4px rgba(0,0,0,0.5); }
.dungeon-index-subtitle { color: #aaa; font-size: 14px; }

.dungeon-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; padding: 20px; }
.dungeon-card { background: #222; border-radius: 12px; overflow: hidden; text-decoration: none; border: 1px solid rgba(255,255,255,0.05); transition: all 0.3s ease; box-shadow: 0 4px 6px rgba(0,0,0,0.3); }
.dungeon-card:hover { transform: translateY(-5px); border-color: #ff9800; box-shadow: 0 8px 15px rgba(255,152,0,0.2); }

.dungeon-card-img-wrapper { height: 160px; background: #333; display: flex; align-items: center; justify-content: center; overflow: hidden; }
.dungeon-card-img-wrapper img { max-width: 100%; max-height: 100%; object-fit: contain; }

.dungeon-card-content { padding: 20px; }
.dungeon-card-name { font-size: 20px; color: #fff; margin-bottom: 15px; font-weight: bold; }
.dungeon-card-meta { margin-bottom: 8px; font-size: 13px; }
.dungeon-meta-label { color: #888; }
.dungeon-meta-value { color: #ddd; }

.dungeon-card-btn { display: inline-block; margin-top: 15px; padding: 8px 20px; background: #ff9800; color: #000; border-radius: 20px; font-size: 12px; font-weight: bold; transition: background 0.2s; }
.dungeon-card:hover .dungeon-card-btn { background: #ffeb3b; }
</style>
