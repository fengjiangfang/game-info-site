---
layout: layout.njk
title: 主題副本總覽
---
{% from "dungeon-macros.njk" import banner %}
{{ banner(site.name + '主題副本', true) }}

<div class="forum-main-card">
    <div class="dungeon-overview-container">
        <!-- 左側：圖片預覽 -->
        <div class="dungeon-preview-side">
            <div class="modern-preview-card">
                <div id="theme-preview-container" class="preview-image-wrapper">
                    <img class="active-img" src="{{ '/images/主題副本/菇菇王國.webp' | url }}" alt="副本圖影" onerror="window.globalImageErrorFallback(this)">
                </div>
            </div>
        </div>

        <!-- 右側：副本列表 -->
        <div class="dungeon-list-side">
            <ul class="dungeon-card-list">
                <li class="dungeon-card-item active" 
                    onmouseover="setActiveDungeon(this, 'theme-preview-container', '{{ '/images/主題副本/菇菇王國.webp' | url }}', 0)">
                    <div class="card-item-info">
                        <span class="card-item-lvl">Lv.30 ↑</span>
                        <span class="card-item-name">菇菇王國</span>
                    </div>
                    <div class="card-item-action">
                        <a href="{{ '/主題副本/菇菇王國/' | url }}" class="card-go-btn">出發 ➔</a>
                    </div>
                </li>

                <li class="dungeon-card-item" 
                    onmouseover="setActiveDungeon(this, 'theme-preview-container', '{{ '/images/主題副本/里艾那海峽.webp' | url }}', 1)">
                    <div class="card-item-info">
                        <span class="card-item-lvl">Lv.40 ↑</span>
                        <span class="card-item-name">里艾那海峽</span>
                    </div>
                    <div class="card-item-action">
                        <a href="{{ '/主題副本/里艾那海峽/' | url }}" class="card-go-btn">出發 ➔</a>
                    </div>
                </li>

                <li class="dungeon-card-item" 
                    onmouseover="setActiveDungeon(this, 'theme-preview-container', '{{ '/images/主題副本/埃羅汀.webp' | url }}', 2)">
                    <div class="card-item-info">
                        <span class="card-item-lvl">Lv.50 ↑</span>
                        <span class="card-item-name">埃羅汀</span>
                    </div>
                    <div class="card-item-action">
                        <a href="{{ '/主題副本/埃羅汀/' | url }}" class="card-go-btn">出發 ➔</a>
                    </div>
                </li>

                <li class="dungeon-card-item" 
                    onmouseover="setActiveDungeon(this, 'theme-preview-container', '{{ '/images/主題副本/帕爾坦.webp' | url }}', 3)">
                    <div class="card-item-info">
                        <span class="card-item-lvl">Lv.60 ↑</span>
                        <span class="card-item-name">帕爾坦</span>
                    </div>
                    <div class="card-item-action">
                        <a href="{{ '/主題副本/帕爾坦/' | url }}" class="card-go-btn">出發 ➔</a>
                    </div>
                </li>

                <li class="dungeon-card-item" 
                    onmouseover="setActiveDungeon(this, 'theme-preview-container', '{{ '/images/主題副本/克里提亞斯.webp' | url }}', 4)">
                    <div class="card-item-info">
                        <span class="card-item-lvl">Lv.70 ↑</span>
                        <span class="card-item-name">克里提亞斯</span>
                    </div>
                    <div class="card-item-action">
                        <a href="{{ '/主題副本/克里提亞斯/' | url }}" class="card-go-btn">出發 ➔</a>
                    </div>
                </li>
            </ul>
        </div>
    </div>
</div>
