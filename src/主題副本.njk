---
layout: layout.njk
title: 主題副本總覽
---
<div class="forum-banner">
    <div class="forum-banner-content" style="text-align: center;">
        <h1>{{ site.name }}主題副本</h1>
    </div>
</div>

<div class="forum-main-card forum-main-card-warm">
    <div style="display: flex; gap: 50px; align-items: center; flex-wrap: wrap;">
        <div style="flex: 7; margin-bottom: 20px;">
            <div style="border-radius: 24px; padding: 15px; background-color: #ffffff; box-shadow: 0 10px 30px rgba(255, 159, 67, 0.15); border: 2px solid #ffeaa7;">
                <div id="theme-preview-container" style="aspect-ratio: 4/3; width: 100%; overflow: hidden; border-radius: 16px; background-color: #fffbf0; position: relative;">
                    <img class="active-img" src="{{ '/images/主題副本/菇菇王國.webp' | url }}" alt="副本圖影" onerror="window.globalImageErrorFallback(this)">
                </div>
            </div>
        </div>

        <div style="flex: 3; padding-top: 5px; height: 546px; display: flex; flex-direction: column; justify-content: center;">
            <ul class="dungeon-timeline">
                <li class="timeline-item timeline-dungeon-box active">
                    <div class="timeline-marker"></div>
                    <div class="dungeon-flag-wrapper" 
                         onmouseover="setActiveDungeon(this, 'theme-preview-container', '{{ '/images/主題副本/菇菇王國.webp' | url }}', 0)">
                        <div class="dungeon-flag">
                            <div class="timeline-dungeon-title"><span class="timeline-dungeon-lvl">Lv.30</span><span>菇菇王國</span></div><a href="{{ '/主題副本/菇菇王國/' | url }}" class="go-btn" onclick="event.stopPropagation();">出發 ➔</a>
                        </div>
                    </div>
                </li>
                <li class="timeline-item timeline-dungeon-box">
                    <div class="timeline-marker"></div>
                    <div class="dungeon-flag-wrapper" 
                         onmouseover="setActiveDungeon(this, 'theme-preview-container', '{{ '/images/主題副本/里艾那海峽.webp' | url }}', 1)">
                        <div class="dungeon-flag">
                            <div class="timeline-dungeon-title"><span class="timeline-dungeon-lvl">Lv.40</span><span>里艾那海峽</span></div><a href="{{ '/主題副本/里艾那海峽/' | url }}" class="go-btn" onclick="event.stopPropagation();">出發 ➔</a>
                        </div>
                    </div>
                </li>
                <li class="timeline-item timeline-dungeon-box">
                    <div class="timeline-marker"></div>
                    <div class="dungeon-flag-wrapper" 
                         onmouseover="setActiveDungeon(this, 'theme-preview-container', '{{ '/images/主題副本/埃羅汀.webp' | url }}', 2)">
                        <div class="dungeon-flag">
                            <div class="timeline-dungeon-title"><span class="timeline-dungeon-lvl">Lv.50</span><span>埃羅汀</span></div><a href="{{ '/主題副本/埃羅汀/' | url }}" class="go-btn" onclick="event.stopPropagation();">出發 ➔</a>
                        </div>
                    </div>
                </li>
                <li class="timeline-item timeline-dungeon-box">
                    <div class="timeline-marker"></div>
                    <div class="dungeon-flag-wrapper" 
                         onmouseover="setActiveDungeon(this, 'theme-preview-container', '{{ '/images/主題副本/帕爾坦.webp' | url }}', 3)">
                        <div class="dungeon-flag">
                            <div class="timeline-dungeon-title"><span class="timeline-dungeon-lvl">Lv.60</span><span>帕爾坦</span></div><a href="{{ '/主題副本/帕爾坦/' | url }}" class="go-btn" onclick="event.stopPropagation();">出發 ➔</a>
                        </div>
                    </div>
                </li>
                <li class="timeline-item timeline-dungeon-box">
                    <div class="timeline-marker"></div>
                    <div class="dungeon-flag-wrapper" 
                         onmouseover="setActiveDungeon(this, 'theme-preview-container', '{{ '/images/主題副本/克里提亞斯.webp' | url }}', 4)">
                        <div class="dungeon-flag">
                            <div class="timeline-dungeon-title"><span class="timeline-dungeon-lvl">Lv.70</span><span>克里提亞斯</span></div><a href="{{ '/主題副本/克里提亞斯/' | url }}" class="go-btn" onclick="event.stopPropagation();">出發 ➔</a>
                        </div>
                    </div>
                </li>
            </ul>
        </div>
    </div>
</div>
