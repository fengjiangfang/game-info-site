{% set cn = ['', '一', '二', '三', '四', '五', '六', '七', '八', '九', '十'] %}

{# ── 通用 ──────────────────────────────────────────── #}

{% macro banner(title, center=false) %}
<div class="forum-banner">
    <div class="forum-banner-content"{% if center %} style="text-align: center;"{% endif %}>
        <h1>{{ title | safe }}</h1>
    </div>
</div>
{% endmacro %}

{% macro tip(text) %}
<li><span class="tip-text">💡 {{ text | safe }}</span></li>
{% endmacro %}

{# ── 副本 Header ────────────────────────────────────── #}

{% macro dungeonHeader(level, players, exp, rewards, dungeon, location, type='組隊副本') %}
<div class="dungeon-info-header">
    <div class="dungeon-info-left dungeon-card">
        <div class="dungeon-reward-box">
            <div class="dungeon-reward-header">副本獎勵資訊</div>
            <div class="reward-table-body">
                <div class="reward-content-row">
                    <div class="reward-col">
                        <div class="reward-col-sub">
                            <span class="reward-sub-label">通關獎勵</span>
                            <div class="reward-items-wrapper">
                                {% for r in rewards.clear %}
                                <div class="reward-item-row">
                                    <div class="item-info">{{ itemBold(r.name) }}</div>
                                    <div class="reward-item-right">{{ r.value }}</div>
                                </div>
                                {% endfor %}
                            </div>
                        </div>

                        <div class="reward-col-sub">
                            <span class="reward-sub-label">機率獲得</span>
                            <div class="reward-items-wrapper">
                                {% for r in rewards.chance %}
                                <div class="reward-item-row">
                                    <div class="item-info">{{ itemBold(r.name) }}</div>
                                    <div class="reward-item-right">{{ r.value }}</div>
                                </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>

                    <div class="reward-col">
                        <div class="reward-col-sub">
                            <span class="reward-sub-label">硬幣兌換</span>
                            <div class="reward-items-wrapper">
                                {% for r in rewards.exchange %}
                                <div class="reward-item-row-triple">
                                    <div class="item-cost"><span class="reward-item-coin-badge">{{ r.cost }}</span></div>
                                    <div class="item-info">{{ itemBold(r.name) }}</div>
                                    <div class="item-value"><div class="reward-item-right">{{ r.value }}</div></div>
                                </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>

                    <div class="reward-col">
                        <div class="reward-col-sub">
                            <span class="reward-sub-label">稱號升級</span>
                            <div class="reward-items-wrapper">
                                {% for r in rewards.run %}
                                <div class="reward-item-row">
                                    <div class="item-info">{{ itemBold(r.name) }}</div>
                                    <div class="reward-item-right">{{ r.value }}</div>
                                </div>
                                <div class="reward-tip-text">最高可升至四屬+3</div>
                                {% endfor %}
                            </div>
                        </div>

                        <div class="reward-col-sub">
                            <span class="reward-sub-label">需求材料</span>
                            <div class="reward-items-wrapper">
                                {% for r in rewards.requirement %}
                                <div class="reward-item-row-double">
                                    <div class="item-cost"><span class="reward-item-coin-badge">{{ r.cost or r.value }}</span></div>
                                    <div class="item-info">{{ item(r.name) }}</div>
                                </div>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="dungeon-info-right dungeon-card">
        <div class="dungeon-npc-img">
            <img src="{{ ('/images/' + type + '/' + dungeon + '/入場NPC.webp') | url }}" onerror="window.globalImageErrorFallback(this)">
        </div>
        <div class="dungeon-stat-grid">
            <div class="stat-box"><span class="stat-label">等級限定</span><span class="stat-value">{{ level }}</span></div>
            <div class="stat-box"><span class="stat-label">入場人數</span><span class="stat-value">{{ players }}</span></div>
            <div class="stat-box"><span class="stat-label">通關經驗</span><span class="stat-value">{{ exp }}</span></div>
        </div>
        <div class="dungeon-location-badge">
            <i class="fa-solid fa-map-location-dot"></i>
            <span class="location-prefix">入場地圖</span><span class="location-name">{{ location }}</span>
        </div>
    </div>
</div>
{% endmacro %}

{# 組隊副本通用標頭（固定獎勵結構快捷版）
   prefix 例：'毒霧組隊' → 自動帶入硬幣、騎寵、稱號 #}
{% macro partyDungeonHeader(level, players, exp, prefix, location, dungeon) %}
{{ dungeonHeader(level, players, exp, {
    clear: [
        { name: prefix + '硬幣', value: '1 個' },
        { name: '洗血精華秘藥罐', value: '10 個' }
    ],
    chance: [
        { name: '轉蛋券', value: '1 個' }
    ],
    exchange: [
        { name: '經驗加倍券', cost: '5 硬幣', value: '四屬+1' },
        { name: prefix + '騎寵', cost: '20 硬幣', value: '四屬+1' }
    ],
    run: [
        { name: prefix + '稱號', value: '四屬+1' }
    ],
    requirement: [
        { name: prefix + '硬幣', value: '1 個' },
        { name: '一百萬楓幣袋', value: '10 個' }
    ]
}, dungeon, location) }}
{% endmacro %}

{# ── 階段列 ─────────────────────────────────────────── #}

{% macro stageRow(num, title, dungeon, ext='webp', type='組隊副本') %}
<li class="timeline-row">
    <div class="timeline-marker"></div>
    <div class="timeline-left-panel">
        <img src="{{ ('/images/' + type + '/' + dungeon + '/第' + cn[num] + '階段.' + ext) | url }}" id="stage-{{ num }}-img" onerror="window.globalImageErrorFallback(this)">
        <div class="stage-legend">
            <span id="stage-{{ num }}-img-caption" class="stage-caption">第{{ cn[num] }}階段</span>
        </div>
    </div>
    <div class="dungeon-flag-wrapper">
        <div class="dungeon-flag-large">
            <div class="stage-color-bar">
                <h3 class="stage-header">
                    <span class="stage-badge">第{{ cn[num] }}階段</span>
                    <span class="stage-title">{{ title | safe }}</span>
                </h3>
                {{ caller() }}
            </div>
        </div>
    </div>
</li>
{% endmacro %}

{# ── NPC / 怪物 hover ────────────────────────────────── #}

{% macro npc(name, img, stage, type='組隊副本', color='#27ae60') %}
<strong class="npc-hover" onmouseover="setHoverImg('{{ ('/images/' + type + '/' + img.replace('.png', '.webp').replace('.gif', '.webp')) | url }}', 'stage-{{ stage }}-img', '{{ name }}', '{{ color }}')" onmouseout="resetHoverImg('stage-{{ stage }}-img')">{{ name }}</strong>
{%- endmacro %}

{% macro mob(name, img, stage, type='組隊副本', color='#9b59b6') %}
<strong class="mob-hover" onmouseover="setHoverImg('{{ ('/images/' + type + '/' + img.replace('.png', '.webp').replace('.gif', '.webp')) | url }}', 'stage-{{ stage }}-img', '{{ name }}', '{{ color }}')" onmouseout="resetHoverImg('stage-{{ stage }}-img')">{{ name }}</strong>
{%- endmacro %}

{# ── 道具 ────────────────────────────────────────────── #}

{% macro item(name) -%}
<span class="item-text"><img src="{{ ('/images/icon/' + name + '.webp') | url }}" class="text-icon" onerror="window.globalImageErrorFallback(this)">{{ name }}</span>
{%- endmacro %}

{% macro itemBold(name) -%}
<span class="item-text-bold"><img src="{{ ('/images/icon/' + name + '.webp') | url }}" class="text-icon" onerror="window.globalImageErrorFallback(this)">{{ name }}</span>
{%- endmacro %}

{# ── 副本導覽列 ──────────────────────────────────────── #}

{% macro dungeonNav(type, prev, next) %}
<div class="dungeon-nav">
    <div class="dungeon-nav-inner">
        {% if prev %}
        <div class="dungeon-nav-prev">
            <a href="{{ ('/' + type + '副本/' + prev + '/') | url }}" class="nav-side-btn"><i class="fa-solid fa-arrow-left"></i> {{ prev }}</a>
        </div>
        {% endif %}

        <a href="{{ ('/' + type + '副本/') | url }}" class="nav-center-btn">返回{{ type }}副本總覽</a>

        {% if next %}
        <div class="dungeon-nav-next">
            <a href="{{ ('/' + type + '副本/' + next + '/') | url }}" class="nav-side-btn">{{ next }} <i class="fa-solid fa-arrow-right"></i></a>
        </div>
        {% endif %}
    </div>
</div>
{% endmacro %}
