<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ site.name }}{% if title %}｜{{ title }}{% endif %}</title>
    <link rel="stylesheet" href="{{ '/style.css' | url }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>
        window.globalImageErrorFallback = function(img) {
            img.dataset.hasError = 'true';
            let nextSrc = '';
            
            // 偵測順序：WebP (最輕) -> PNG (靜態) -> GIF (動態) -> JPG (相容)
            if (!img.dataset.triedWebp) {
                img.dataset.triedWebp = 'true';
                nextSrc = img.src.replace(/\.(gif|png|jpg|jpeg)$/i, '.webp');
            } else if (!img.dataset.triedPng) {
                img.dataset.triedPng = 'true';
                nextSrc = img.src.replace(/\.(gif|webp|jpg|jpeg)$/i, '.png');
            } else if (!img.dataset.triedGif) {
                img.dataset.triedGif = 'true';
                nextSrc = img.src.replace(/\.(webp|png|jpg|jpeg)$/i, '.gif');
            } else if (!img.dataset.triedJpg) {
                img.dataset.triedJpg = 'true';
                nextSrc = img.src.replace(/\.(webp|png|gif|jpeg)$/i, '.jpg');
            } else {
                img.onerror = null;
                img.src = 'https://placehold.co/600x450/fff4e6/ff9f43?text=NO+IMAGE&font=Oswald';
                return;
            }

            if (nextSrc) {
                img.src = nextSrc;
                img.__originalSrc = nextSrc;
            }
        };
    </script>
</head>
<body>
    {% macro navLink(url, label, prefix='　　├ ') %}
        <a href="{{ url | url }}" class="channel-item sub-channel {% if page.url == url %}active{% endif %}">
            <span class="channel-name">{{ prefix }}{{ label }}</span>
        </a>
    {% endmacro %}

    <div class="app-container">
        <nav class="sidebar">
            <div class="server-header">
                <span>【 {{ site.name }}資訊 】</span>
                <i class="fa-solid fa-chevron-down"></i>
            </div>
            <div class="channel-list">

                <details class="channel-group main-group" id="group-server" {% if page.url and (page.url == '/基礎設置/' or page.url == '/遊戲規章/') %}open{% endif %}>
                    <summary class="channel-item category-header">
                        <span class="channel-name">⚙️《 {{ site.name }}相關 》</span>
                    </summary>
                    <div class="sub-channel-container">
                        <a href="{{ '/基礎設置/' | url }}" class="channel-item sub-channel {% if page.url == '/基礎設置/' %}active{% endif %}">
                            <span class="channel-name">　☆ 基礎設置</span>
                        </a>
                        <a href="{{ '/遊戲規章/' | url }}" class="channel-item sub-channel {% if page.url == '/遊戲規章/' %}active{% endif %}">
                            <span class="channel-name">　☆ 遊戲規章</span>
                        </a>
                    </div>
                </details>

                <details class="channel-group main-group" id="group-features" {% if page.url and ('/主題副本/' in page.url or '/組隊副本/' in page.url) %}open{% endif %}>
                    <summary class="channel-item category-header">
                        <span class="channel-name">🌟《 {{ site.name }}特色 》</span>
                    </summary>
                    <div class="sub-channel-container">

                        <details class="channel-group feature-subgroup" id="subgroup-theme" {% if page.url and (page.url == '/主題副本/' or '/主題副本/' in page.url) %}open{% endif %}>
                            <summary class="channel-item sub-channel {% if page.url == '/主題副本/' %}active{% endif %}" onclick="if(this.parentNode.open){event.preventDefault();} window.location.href='{{ '/主題副本/' | url }}';" style="cursor: pointer;">
                                <span class="channel-name">　★ 主題副本</span>
                            </summary>
                            <div class="sub-channel-container" style="padding-left: 8px;">
                                {{ navLink('/主題副本/菇菇王國/', '菇菇王國') }}
                                {{ navLink('/主題副本/里艾那海峽/', '里艾那海峽') }}
                                {{ navLink('/主題副本/埃羅汀/', '埃羅汀') }}
                                {{ navLink('/主題副本/帕爾坦/', '帕爾坦') }}
                                {{ navLink('/主題副本/克里提亞斯/', '克里提亞斯', '　　└ ') }}
                            </div>
                        </details>

                        <details class="channel-group feature-subgroup" id="subgroup-party" {% if page.url and (page.url == '/組隊副本/' or '/組隊副本/' in page.url) %}open{% endif %}>
                            <summary class="channel-item sub-channel {% if page.url == '/組隊副本/' %}active{% endif %}" onclick="if(this.parentNode.open){event.preventDefault();} window.location.href='{{ '/組隊副本/' | url }}';" style="cursor: pointer;">
                                <span class="channel-name">　★ 組隊副本</span>
                            </summary>
                            <div class="sub-channel-container" style="padding-left: 8px;">
                                {{ navLink('/組隊副本/第一次同行/', '第一次同行') }}
                                {{ navLink('/組隊副本/時空的裂縫/', '時空的裂縫') }}
                                {{ navLink('/組隊副本/毒霧森林/', '毒霧森林') }}
                                {{ navLink('/組隊副本/女神的痕跡/', '女神的痕跡') }}
                                {{ navLink('/組隊副本/金勾海賊王/', '金勾海賊王') }}
                                {{ navLink('/組隊副本/羅密歐與茱麗葉/', '羅密歐與茱麗葉', '　　└ ') }}
                            </div>
                        </details>
                    </div>
                </details>

            </div>
        </nav>

        <main class="main-content">
            <div class="page-section active">
                {{ content | safe }}
            </div>
        </main>
    </div>

    <script src="{{ '/js/dungeon-interact.js' | url }}"></script>
    <script src="{{ '/js/sidebar-logic.js' | url }}"></script>
</body>
</html>
