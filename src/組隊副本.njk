---
layout: layout.njk
title: 組隊副本總覽
---
{% from "dungeon-macros.njk" import banner %}
{{ banner(site.name + '組隊副本', true) }}

<div class="forum-main-card">
    <div class="dungeon-overview-container">
        <!-- 左側：圖片預覽 -->
        <div class="dungeon-preview-side">
            <div class="modern-preview-card">
                <div id="party-preview-container" class="preview-image-wrapper">
                    <img class="active-img" src="{{ '/images/組隊副本/第一次同行.webp' | url }}" alt="副本圖影" onerror="window.globalImageErrorFallback(this)">
                </div>
            </div>
        </div>

        <!-- 右側：副本列表 -->
        <div class="dungeon-list-side">
            <ul class="dungeon-card-list">
                <li class="dungeon-card-item active" 
                    onmouseover="setActiveDungeon(this, 'party-preview-container', '{{ '/images/組隊副本/第一次同行.webp' | url }}', 0)">
                    <div class="card-item-info">
                        <span class="card-item-lvl">Lv.21 ↑</span>
                        <span class="card-item-name">第一次同行</span>
                    </div>
                    <div class="card-item-action">
                        <a href="{{ '/組隊副本/第一次同行/' | url }}" class="card-go-btn">出發 ➔</a>
                    </div>
                </li>

                <li class="dungeon-card-item" 
                    onmouseover="setActiveDungeon(this, 'party-preview-container', '{{ '/images/組隊副本/時空的裂縫.webp' | url }}', 1)">
                    <div class="card-item-info">
                        <span class="card-item-lvl">Lv.35 ↑</span>
                        <span class="card-item-name">時空的裂縫</span>
                    </div>
                    <div class="card-item-action">
                        <a href="{{ '/組隊副本/時空的裂縫/' | url }}" class="card-go-btn">出發 ➔</a>
                    </div>
                </li>

                <li class="dungeon-card-item" 
                    onmouseover="setActiveDungeon(this, 'party-preview-container', '{{ '/images/組隊副本/毒霧森林.webp' | url }}', 2)">
                    <div class="card-item-info">
                        <span class="card-item-lvl">Lv.45 ↑</span>
                        <span class="card-item-name">毒霧森林</span>
                    </div>
                    <div class="card-item-action">
                        <a href="{{ '/組隊副本/毒霧森林/' | url }}" class="card-go-btn">出發 ➔</a>
                    </div>
                </li>

                <li class="dungeon-card-item" 
                    onmouseover="setActiveDungeon(this, 'party-preview-container', '{{ '/images/組隊副本/女神的痕跡.webp' | url }}', 3)">
                    <div class="card-item-info">
                        <span class="card-item-lvl">Lv.51 ↑</span>
                        <span class="card-item-name">女神的痕跡</span>
                    </div>
                    <div class="card-item-action">
                        <a href="{{ '/組隊副本/女神的痕跡/' | url }}" class="card-go-btn">出發 ➔</a>
                    </div>
                </li>

                <li class="dungeon-card-item" 
                    onmouseover="setActiveDungeon(this, 'party-preview-container', '{{ '/images/組隊副本/金勾海賊王.webp' | url }}', 4)">
                    <div class="card-item-info">
                        <span class="card-item-lvl">Lv.55 ↑</span>
                        <span class="card-item-name">金勾海賊王</span>
                    </div>
                    <div class="card-item-action">
                        <a href="{{ '/組隊副本/金勾海賊王/' | url }}" class="card-go-btn">出發 ➔</a>
                    </div>
                </li>

                <li class="dungeon-card-item" 
                    onmouseover="setActiveDungeon(this, 'party-preview-container', '{{ '/images/組隊副本/羅密歐與茱麗葉.webp' | url }}', 5)">
                    <div class="card-item-info">
                        <span class="card-item-lvl">Lv.71 ↑</span>
                        <span class="card-item-name">羅密歐與茱麗葉</span>
                    </div>
                    <div class="card-item-action">
                        <a href="{{ '/組隊副本/羅密歐與茱麗葉/' | url }}" class="card-go-btn">出發 ➔</a>
                    </div>
                </li>
            </ul>
        </div>
    </div>
</div>
