---
layout: layout.njk
title: 組隊副本總覽
---
{% from "dungeon-macros.njk" import banner %}
{{ banner(site.name + '組隊副本', true) }}

<div class="forum-main-card forum-main-card-warm">
    <div style="display: flex; gap: 50px; align-items: center; flex-wrap: wrap;">
        <div style="flex: 7; margin-bottom: 20px;">
            <div style="border-radius: 24px; padding: 15px; background-color: #ffffff; box-shadow: 0 10px 30px rgba(255, 159, 67, 0.15); border: 2px solid #ffeaa7;">
                <div id="party-preview-container" style="aspect-ratio: 4/3; width: 100%; overflow: hidden; border-radius: 16px; background-color: #fffbf0; position: relative;">
                    <img class="active-img" src="{{ '/images/組隊副本/第一次同行.webp' | url }}" alt="副本圖影" onerror="window.globalImageErrorFallback(this)">
                </div>
            </div>
        </div>

        <div style="flex: 3; padding-top: 5px; height: 546px; display: flex; flex-direction: column; justify-content: center;">
            <ul class="dungeon-timeline">
                <li class="timeline-item timeline-dungeon-box active">
                    <div class="timeline-marker"></div>
                    <div class="dungeon-flag-wrapper" 
                         onmouseover="setActiveDungeon(this, 'party-preview-container', '{{ '/images/組隊副本/第一次同行.webp' | url }}', 0)">
                        <div class="dungeon-flag">
                            <div class="timeline-dungeon-title"><span class="timeline-dungeon-lvl">Lv.21</span><span>第一次同行</span></div><a href="{{ '/組隊副本/第一次同行/' | url }}" class="go-btn" onclick="event.stopPropagation();">出發 ➔</a>
                        </div>
                    </div>
                </li>
                <li class="timeline-item timeline-dungeon-box">
                    <div class="timeline-marker"></div>
                    <div class="dungeon-flag-wrapper" 
                         onmouseover="setActiveDungeon(this, 'party-preview-container', '{{ '/images/組隊副本/時空的裂縫.webp' | url }}', 1)">
                        <div class="dungeon-flag">
                            <div class="timeline-dungeon-title"><span class="timeline-dungeon-lvl">Lv.35</span><span>時空的裂縫</span></div><a href="{{ '/組隊副本/時空的裂縫/' | url }}" class="go-btn" onclick="event.stopPropagation();">出發 ➔</a>
                        </div>
                    </div>
                </li>
                <li class="timeline-item timeline-dungeon-box">
                    <div class="timeline-marker"></div>
                    <div class="dungeon-flag-wrapper" 
                         onmouseover="setActiveDungeon(this, 'party-preview-container', '{{ '/images/組隊副本/毒霧森林.webp' | url }}', 2)">
                        <div class="dungeon-flag">
                            <div class="timeline-dungeon-title"><span class="timeline-dungeon-lvl">Lv.45</span><span>毒霧森林</span></div><a href="{{ '/組隊副本/毒霧森林/' | url }}" class="go-btn" onclick="event.stopPropagation();">出發 ➔</a>
                        </div>
                    </div>
                </li>
                <li class="timeline-item timeline-dungeon-box">
                    <div class="timeline-marker"></div>
                    <div class="dungeon-flag-wrapper" 
                         onmouseover="setActiveDungeon(this, 'party-preview-container', '{{ '/images/組隊副本/女神的痕跡.webp' | url }}', 3)">
                        <div class="dungeon-flag">
                            <div class="timeline-dungeon-title"><span class="timeline-dungeon-lvl">Lv.51</span><span>女神的痕跡</span></div><a href="{{ '/組隊副本/女神的痕跡/' | url }}" class="go-btn" onclick="event.stopPropagation();">出發 ➔</a>
                        </div>
                    </div>
                </li>
                <li class="timeline-item timeline-dungeon-box">
                    <div class="timeline-marker"></div>
                    <div class="dungeon-flag-wrapper" 
                         onmouseover="setActiveDungeon(this, 'party-preview-container', '{{ '/images/組隊副本/金勾海賊王.webp' | url }}', 4)">
                        <div class="dungeon-flag">
                            <div class="timeline-dungeon-title"><span class="timeline-dungeon-lvl">Lv.55</span><span>金勾海賊王</span></div><a href="{{ '/組隊副本/金勾海賊王/' | url }}" class="go-btn" onclick="event.stopPropagation();">出發 ➔</a>
                        </div>
                    </div>
                </li>
                <li class="timeline-item timeline-dungeon-box">
                    <div class="timeline-marker"></div>
                    <div class="dungeon-flag-wrapper" 
                         onmouseover="setActiveDungeon(this, 'party-preview-container', '{{ '/images/組隊副本/羅密歐與茱麗葉.webp' | url }}', 5)">
                        <div class="dungeon-flag">
                            <div class="timeline-dungeon-title"><span class="timeline-dungeon-lvl">Lv.70</span><span>羅密歐與茱麗葉</span></div><a href="{{ '/組隊副本/羅密歐與茱麗葉/' | url }}" class="go-btn" onclick="event.stopPropagation();">出發 ➔</a>
                        </div>
                    </div>
                </li>
            </ul>
        </div>
    </div>
</div>
